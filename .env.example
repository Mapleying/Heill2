# ── Flights: Aviasales / Travelpayouts ──────────────────────────────────────
# Sign up at https://travelpayouts.com → Account → API Tokens
# Free to use with attribution requirement (include affiliate marker in links)
AVIASALES_TOKEN=0f47361980fbba4f4d56a832ddb5a790
AVIASALES_MARKER=737217    # optional; used in booking deep-links

# ── Hotels: Booking.com Affiliate Demand API ─────────────────────────────────
# Apply at https://www.booking.com/affiliate-program/partner/signup
# You will receive an Affiliate ID (numeric) and an API key after approval
BOOKING_AFFILIATE_ID=your_numeric_affiliate_id
BOOKING_API_KEY=your_booking_api_key

# ── AI Agent: Google Gemini ───────────────────────────────────────────────────
# Required for natural language understanding. Get a free key at:
# https://aistudio.google.com/app/apikey
# When set here, ALL conversations use Gemini automatically.
# Users can still override with their own key via the settings modal.
GEMINI_API_KEY=your_gemini_api_key_here
